---
// src/components/home/CTABentoCell.astro
// Consultation CTA cell (2x1 wide) for bento grid.

import { base } from '../../utils/paths';
---

<div class="bento-cell bento-cell--span-2 cta-cell">
	<h2 class="cta-cell__heading">Let's work together</h2>
	<p class="cta-cell__text">I bring 15 years of systems thinking to every engagement.</p>
	<div class="cta-cell__actions">
		<a href={`${base}consult/`} class="cta-cell__btn cta-cell__btn--primary">Start a conversation</a>
		<a href="mailto:etceter4@etceter4.com" class="cta-cell__btn cta-cell__btn--secondary"
			>Email directly</a
		>
	</div>
</div>

<style>
	.cta-cell {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.cta-cell__heading {
		font-family: var(--font-heading);
		font-size: 1.3rem;
		margin-bottom: var(--space-xs);
	}

	.cta-cell__text {
		font-size: 0.9rem;
		color: var(--text-secondary);
		margin-bottom: var(--space-md);
	}

	.cta-cell__actions {
		display: flex;
		gap: var(--space-sm);
		flex-wrap: wrap;
	}

	.cta-cell__btn {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		padding: var(--space-xs) var(--space-md);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: all var(--transition-fast);
	}

	.cta-cell__btn--primary {
		background: var(--accent);
		color: var(--bg-primary);
	}

	.cta-cell__btn--primary:hover {
		background: var(--accent-hover);
	}

	.cta-cell__btn--secondary {
		border: 1px solid var(--border);
		color: var(--text-secondary);
	}

	.cta-cell__btn--secondary:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
</style>
