---
import ChartContainer from '../components/charts/ChartContainer.astro';
import FlagshipTable from '../components/dashboard/FlagshipTable.astro';
import OrganStatus from '../components/dashboard/OrganStatus.astro';
import PraxisTargets from '../components/dashboard/PraxisTargets.astro';
import QualityGates from '../components/dashboard/QualityGates.astro';
import QualityScoreboard from '../components/dashboard/QualityScoreboard.astro';
import ScoutTriage from '../components/dashboard/ScoutTriage.astro';
import SprintTimeline from '../components/dashboard/SprintTimeline.astro';
import StrikeLog from '../components/dashboard/StrikeLog.astro';
import WorkspaceHealth from '../components/dashboard/WorkspaceHealth.astro';
import PrismNav from '../components/PrismNav.astro';
import StatGrid from '../components/StatGrid.astro';
import SketchContainer from '../components/sketches/SketchContainer.astro';
import graphData from '../data/graph.json';
import { organColors } from '../data/organ-colors';
import qualityData from '../data/quality-metrics.json';
import metrics from '../data/system-metrics.json';
import vitals from '../data/vitals.json';
import Layout from '../layouts/Layout.astro';
import type { Organ, PraxisTarget, QualityMetrics, SystemMetrics } from '../types/data';
import { base } from '../utils/paths';

const quality = qualityData as unknown as QualityMetrics;

const typedMetrics = metrics as unknown as SystemMetrics;

// Support both new schema (computed.per_organ) and legacy schema (registry.organs)
const rawMetrics = metrics as unknown as Record<string, unknown>;
const computed = (rawMetrics.computed ?? {}) as Record<string, unknown>;
const legacyRegistry = (rawMetrics.registry ?? {}) as Record<string, unknown>;

// Build organs map from whichever schema is present
const perOrganRaw = (computed.per_organ ?? legacyRegistry.organs ?? {}) as Record<
	string,
	Record<string, unknown>
>;
const organsMap: Record<string, Organ> = Object.fromEntries(
	Object.entries(perOrganRaw).map(([key, o]) => [
		key,
		{
			name: String(o.name ?? key),
			status: String(o.status ?? 'active'),
			total_repos: Number(o.repos ?? o.total_repos ?? 0),
			implementation_status: (o.implementation_status as Record<string, number>) ?? {},
			tier_distribution: (o.tier_distribution as Record<string, number>) ?? {},
			ci_coverage: Number(o.ci_coverage ?? 0),
		} satisfies Organ,
	]),
);

// Registry shim: merge legacy registry with computed fields for backward-compat references
const registryShim = {
	total_repos: Number(computed.total_repos ?? legacyRegistry.total_repos ?? 0),
	implementation_status: (computed.implementation_status ??
		legacyRegistry.implementation_status ??
		{}) as Record<string, number>,
	organs: organsMap,
};

const organNames = Object.keys(organsMap);
const repoCounts = Object.values(organsMap).map((o: Organ) => o.total_repos);

const organChartData = {
	organs: Object.entries(organsMap).map(([key, organ]: [string, Organ]) => ({
		key,
		name: organ.name,
		total_repos: organ.total_repos,
		ci_coverage: organ.ci_coverage,
	})),
};

const classificationChartData = {
	classifications: typedMetrics.flagship_vivification?.classifications || {},
	total: typedMetrics.flagship_vivification?.total_audited || 0,
};

const sprintChartData = { sprints: typedMetrics.sprint_history || [] };

const treemapData = {
	organs: Object.entries(organsMap).map(([key, organ]: [string, Organ]) => ({
		key,
		name: organ.name,
		total_repos: organ.total_repos,
	})),
};

const praxisChartData = {
	targets: Object.entries(typedMetrics.praxis_targets || {}).map(
		([key, target]: [string, PraxisTarget]) => ({
			key,
			label: key.replace(/_/g, ' '),
			current: String(target.current).replace(/[^0-9.]/g, '') || '0',
			target: String(target.target).replace(/[^0-9.]/g, '') || '1',
			met: !!target.met,
		}),
	),
};

const flagshipChartData = { repos: typedMetrics.flagship_vivification?.repos || [] };
---

<Layout title="Operative Dashboard — System Command" description={`Live technical and strategic vitals for the ${vitals.repos.total}-repository creative-institutional system.`}>
    <div class="sketch-accent">
      <SketchContainer
        sketchId="data-bars"
        height="var(--space-4xl)"
        mobileHeight="var(--space-3xl)"
        ariaLabel="Animated data bar visualization representing system metrics"
        title="Metric Pulse"
        caption="Real-time distribution of repositories across the system architecture."
        dataSource="System Metrics JSON"
        data-values={repoCounts.join(',')}
        data-labels={organNames.join(',')}
      />
    </div>
    <section class="section">
      <div class="container">
        <h1 class="page-title">Operative Dashboard</h1>
        <p class="page-sub">Live orchestration vitals from {vitals.repos.total} repositories across {vitals.repos.orgs} organs.</p>

        <StatGrid stats={[
          { value: vitals.substance.code_files.toLocaleString(), label: 'Code Files' },
          { value: vitals.substance.test_files, label: 'Test Files' },
          { value: vitals.substance.ci_passing, label: 'Passing CI Workflows' },
          { value: registryShim.total_repos, label: 'Repositories' },
          { value: registryShim.implementation_status.ACTIVE || 0, label: 'Active' },
          { value: vitals.logos.essays, label: 'Essays' },
        ]} />

        <div class="stack-badges">
          <h2 class="stack-badges__heading">Orchestration Tech Stack</h2>
          <div class="stack-badges__grid">
            {['Python', 'TypeScript', 'React', 'Next.js', 'FastAPI', 'Express', 'Fastify', 'Docker', 'Terraform', 'PostgreSQL', 'Redis', 'Rust', 'Astro', 'p5.js', 'D3.js', 'Solana/Anchor'].map(tech => (
              <span class="stack-badge">{tech}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <QualityGates quality={quality} base={base} />

    <QualityScoreboard quality={quality} />

    <section class="section">
      <div class="container">
        <ScoutTriage />
        <StrikeLog />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section__heading">Repositories by Organ</h2>
        <div class="chart-pair">
          <ChartContainer
            chartId="organ-bar"
            data={organChartData}
            ariaLabel="Bar chart showing repository count per organ"
            height="var(--space-5xl)"
            title="Repository Counts"
            caption="Comparison of total active repositories managed by each functional Organ."
            dataSource="Registry Data"
          />
          <ChartContainer
            chartId="code-treemap"
            data={treemapData}
            ariaLabel="Treemap showing repository distribution by organ"
            height="var(--space-5xl)"
            title="Structural Density"
            caption="Volume-based mapping of the repository landscape."
            dataSource="Registry Data"
          />
        </div>
      </div>
    </section>

    <OrganStatus organs={organsMap} organColors={organColors} />

    <FlagshipTable
      repos={typedMetrics.flagship_vivification?.repos || []}
      classifications={typedMetrics.flagship_vivification?.classifications || {}}
      totalAudited={typedMetrics.flagship_vivification?.total_audited || 0}
      classificationChartData={classificationChartData}
      flagshipChartData={flagshipChartData}
    />

    <SprintTimeline sprints={typedMetrics.sprint_history || []} sprintChartData={sprintChartData} />

    <section class="section">
      <div class="container">
        <h2 class="section__heading">Dependency Graph</h2>
        <ChartContainer
          chartId="dependency-graph"
          data={graphData}
          ariaLabel="Force-directed graph showing repository dependencies"
          height="var(--space-6xl)"
          title="Internal Dependencies"
          caption="Validated relationship mapping between system components."
          dataSource="Repository Manifests"
        />
      </div>
    </section>

    <PraxisTargets targets={typedMetrics.praxis_targets || {}} praxisChartData={praxisChartData} />

    <section class="section">
      <div class="container">
        <h2 class="section__heading">Personal Workspace</h2>
        <WorkspaceHealth />
      </div>
    </section>

    <PrismNav context="dashboard" />
</Layout>

<script>
  import '../components/charts/chart-loader';
</script>

<style>
  .stack-badges {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    border-top: 1px solid var(--border);
    background: var(--bg-card);
    border-radius: var(--radius);
  }

  .stack-badges__heading {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  .stack-badges__grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .stack-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.3em 0.7em;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    background: var(--bg-card);
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .stack-badge:hover {
    border-color: var(--accent);
    color: var(--accent-text);
  }

  .chart-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .chart-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
