---
import StatGrid from '../components/StatGrid.astro';
import omegaData from '../data/omega.json';
import testimonialsData from '../data/testimonials.json';
import vitals from '../data/vitals.json';
import Layout from '../layouts/Layout.astro';
import type { Testimonial } from '../types/data';
import { base } from '../utils/paths';

const testimonials: Testimonial[] = testimonialsData.testimonials;

const soakDay = omegaData.soak.streak_days;
const targetDay = omegaData.soak.target_days;
const omegaMet = omegaData.summary.met;
const omegaTotal = omegaData.summary.total;
const omegaPct = Math.round((omegaMet / omegaTotal) * 100);

const validationStats = [
	{ value: `${omegaMet}/${omegaTotal}`, label: 'Omega Criteria Met' },
	{ value: `${omegaPct}%`, label: 'Maturity Score' },
	{ value: omegaData.soak.critical_incidents.toString(), label: 'Critical Incidents' },
	{ value: vitals.repos.total.toString(), label: 'Repos Under Governance' },
];

const feedbackCriteria = [
	{
		title: 'Architectural Coherence',
		description: `Does the system maintain logical consistency across all ${vitals.repos.total} repositories?`,
		target: 'Stranger Test Score >= 80%',
	},
	{
		title: 'Operational Runbooks',
		description: 'Can a second operator maintain the system using existing documentation?',
		target: 'Validated by independent audit',
	},
	{
		title: 'External Utility',
		description: 'Do the products in Organ III solve real-world B2B challenges?',
		target: '>= 3 feedback pieces logged',
	},
];
---

<Layout title="Testimonials & Validation — The Stranger Test" description="Protocol and logs for external system validation and community feedback.">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Testimonials & Validation</h1>
      <p class="page-sub">
        The "Stranger Test" is our primary protocol for external validation. A project isn't finished until an uninvolved person can navigate, understand, and operate it.
      </p>

      <div class="omega-banner" data-reveal>
        <div class="omega-banner__label">Omega Maturity Scorecard</div>
        <div class="omega-banner__ratio">{omegaMet}<span class="omega-banner__denom">/{omegaTotal}</span></div>
        <div class="omega-banner__sub">criteria met &mdash; {omegaPct}% maturity</div>
        <a href={`${base}omega/`} class="omega-banner__link">View full scorecard &rarr;</a>
      </div>

      <StatGrid stats={validationStats} />

      <div class="callout">
        <h3>Seeking External Validators</h3>
        <p>
          We are currently in the <strong>Soak Test Phase (Day {soakDay}/{targetDay})</strong>. We are actively seeking technical auditors and systems engineers to perform "Stranger Tests" on the ORGANVM architecture.
        </p>
        <div class="callout__actions">
          <a href={`${base}consult/`} class="btn">Apply to Validate</a>
          <a href={`${base}validation/`} class="btn btn--secondary">View Test Protocol</a>
        </div>
      </div>

      <h2 class="section__heading" data-reveal>Validation Protocol</h2>
      <div class="protocol-grid">
        {feedbackCriteria.map(c => (
          <div class="protocol-card" data-reveal>
            <div class="protocol-card__header">
              <span class="protocol-card__target">{c.target}</span>
            </div>
            <h3>{c.title}</h3>
            <p>{c.description}</p>
          </div>
        ))}
      </div>

      <h2 class="section__heading" data-reveal>Current Feedback Logs</h2>
      {testimonials.length > 0 ? (
        <div class="testimonial-grid">
          {testimonials.map((t) => (
            <figure class="testimonial-card" data-reveal>
              <blockquote class="testimonial-card__quote">{t.quote}</blockquote>
              <figcaption class="testimonial-card__meta">
                <span class="testimonial-card__name">{t.name}</span>
                {t.role && <span class="testimonial-card__role">{t.role}</span>}
                {t.source &&
                  (t.sourceUrl ? (
                    <a
                      class="testimonial-card__source"
                      href={t.sourceUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {t.source}
                    </a>
                  ) : (
                    <span class="testimonial-card__source">{t.source}</span>
                  ))}
              </figcaption>
            </figure>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No external testimonials logged yet. System is currently in autonomous soak mode.</p>
          <p class="small">Refer to <a href={`${base}omega/`}>Omega Criterion #7</a> for tracking status.</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .omega-banner {
    background: var(--bg-card);
    border: 2px solid var(--accent);
    border-radius: 12px;
    padding: var(--space-xl);
    text-align: center;
    margin: var(--space-2xl) 0 var(--space-lg);
  }
  .omega-banner__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }
  .omega-banner__ratio {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .omega-banner__denom {
    color: var(--text-secondary);
    font-size: 0.6em;
  }
  .omega-banner__sub {
    color: var(--text-secondary);
    margin-top: var(--space-xs);
    font-size: 0.95rem;
  }
  .omega-banner__link {
    display: inline-block;
    margin-top: var(--space-md);
    color: var(--accent);
    font-size: 0.9rem;
    text-decoration: none;
    font-weight: 600;
  }
  .omega-banner__link:hover {
    text-decoration: underline;
  }
  .callout {
    background: var(--bg-secondary);
    border: 2px solid var(--accent);
    padding: var(--space-xl);
    border-radius: 12px;
    margin: var(--space-2xl) 0;
    text-align: center;
  }
  .callout h3 {
    margin-top: 0;
    color: var(--accent);
  }
  .callout__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }
  .protocol-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin: var(--space-xl) 0;
  }
  .protocol-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: var(--space-lg);
    border-radius: 8px;
  }
  .protocol-card__target {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cmyk-yellow);
    text-transform: uppercase;
  }
  .empty-state {
    text-align: center;
    padding: var(--space-3xl);
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--text-muted);
  }
  .btn {
    display: inline-block;
    background: var(--accent);
    color: var(--bg-primary);
    padding: var(--space-sm) var(--space-xl);
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
  }
  .btn--secondary {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
  }
  .btn--secondary:hover {
    background: var(--bg-card);
  }
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
    margin: var(--space-xl) 0;
  }
  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-xl);
    margin: 0;
  }
  .testimonial-card__quote {
    margin: 0 0 var(--space-md);
    border-left: 2px solid var(--accent);
    padding-left: var(--space-md);
    color: var(--text-secondary);
    font-style: italic;
  }
  .testimonial-card__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .testimonial-card__name {
    font-weight: 600;
    color: var(--text-primary);
  }
  .testimonial-card__role {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .testimonial-card__source {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    text-decoration: none;
    margin-top: var(--space-xs);
  }
</style>
