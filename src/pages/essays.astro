---
import SketchContainer from '../components/sketches/SketchContainer.astro';
import essayData from '../data/essays.json';
import vitals from '../data/vitals.json';
import Layout from '../layouts/Layout.astro';
import type { Essay, EssayData } from '../types/data';

const typedEssayData = essayData as EssayData;
const essayTitles = typedEssayData.essays.slice(0, 12).map((e: Essay) => e.title);
---

<Layout title="Essays — Thought Leadership" description={`${typedEssayData.total} strategic and technical essays documenting the ${vitals.repos.total}-repository system's architectural evolution.`}>
    <div class="sketch-accent">
      <SketchContainer sketchId="token-stream" height="var(--space-4xl)" mobileHeight="var(--space-3xl)" ariaLabel="Animated token stream representing text and language flow" data-tokens={essayTitles.join('|')} />
    </div>
    <section class="section">
      <div class="container">
        <h1 class="page-title">Thought Leadership</h1>
        <p class="page-sub">
          {typedEssayData.total} long-form analyses documenting architectural invariants, sprint delivery, and creative-institutional methodology. Transparency as evidence; documentation as structural integrity.
        </p>
        <p class="page-feed">
          <a href={typedEssayData.feed_url} target="_blank" rel="noopener noreferrer">RSS Feed</a>
          &middot;
          <a href={typedEssayData.site_url} target="_blank" rel="noopener noreferrer">Full site</a>
        </p>

        <div class="essay-list">
          {typedEssayData.essays.map((essay: Essay) => (
            <a href={essay.url} target="_blank" rel="noopener noreferrer" class="essay-entry">
              <div class="essay-entry__meta">
                <time class="essay-entry__date" datetime={essay.date}>{essay.date}</time>
              </div>
              <div class="essay-entry__content">
                <div class="essay-entry__header-wrap">
                  <h2 class="essay-entry__title">{essay.title}</h2>
                  {essay.category && <span class={`essay-category essay-category--${essay.category.toLowerCase().replace(/\s+/g, '-')}`}>{essay.category}</span>}
                </div>
                {essay.subtitle && <p class="essay-entry__subtitle">{essay.subtitle}</p>}
                {essay.summary && <p class="essay-entry__summary">{essay.summary}</p>}
              </div>
              <span class="essay-entry__cta" aria-hidden="true">Read &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
</Layout>

<style>
  .page-sub {
    margin-bottom: var(--space-sm);
  }

  .page-feed {
    font-size: 0.85rem;
    margin-bottom: var(--space-2xl);
  }

  .essay-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .essay-entry {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: start;
    gap: var(--space-xl);
    padding: var(--space-xl);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: all var(--transition-fast);
    background: var(--bg-secondary);
  }

  .essay-entry:hover {
    background: var(--bg-card);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .essay-entry__date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .essay-entry__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .essay-entry__header-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .essay-entry__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
    transition: color var(--transition-fast);
  }

  .essay-category {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .essay-category--architecture { border-color: var(--cmyk-cyan, #00bcd4); color: var(--cmyk-cyan, #00bcd4); }
  .essay-category--post-mortem { border-color: var(--cmyk-magenta, #e91e63); color: var(--cmyk-magenta, #e91e63); }
  .essay-category--theory { border-color: var(--cmyk-yellow, #ffc107); color: var(--cmyk-yellow, #ffc107); }
  .essay-category--methodology { border-color: var(--accent); color: var(--accent); }

  .essay-entry__subtitle {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-text);
    margin: 0;
    line-height: 1.4;
  }

  .essay-entry__summary {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: var(--space-xs) 0 0;
    line-height: 1.6;
    max-width: 65ch;
  }

  .essay-entry__cta {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
    align-self: center;
    transition: color var(--transition-fast);
  }

  .essay-entry:hover .essay-entry__title {
    color: var(--text-primary);
  }

  .essay-entry:hover .essay-entry__cta {
    color: var(--accent-text);
  }

  @media (max-width: 768px) {
    .essay-entry {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .essay-entry__cta {
      display: none;
    }
  }
</style>
