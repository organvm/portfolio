---
import SketchContainer from '../components/sketches/SketchContainer.astro';
import {
	type ProductAudience,
	type ProductOffer,
	productAudienceLabelMap,
	productOffers,
	statusColors,
	typeBadgeColors,
} from '../data/product-offer';
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/paths';

interface OfferAudienceItem {
	id: ProductAudience;
	label: string;
	tagline: string;
}

interface OfferLink {
	label: string;
	href: string;
	external: boolean;
	variant: 'primary' | 'secondary' | 'proof';
}

const audienceOptions: OfferAudienceItem[] = [
	{
		id: 'clients',
		label: productAudienceLabelMap.clients,
		tagline: 'Commercial outcomes, direct ownership.',
	},
	{
		id: 'collaborators',
		label: productAudienceLabelMap.collaborators,
		tagline: 'Open contribution and co-build opportunities.',
	},
	{
		id: 'investors',
		label: productAudienceLabelMap.investors,
		tagline: 'Proof of execution and growth-readiness.',
	},
];

const audienceParam = Astro.url.searchParams.get('audience');
const selectedAudience = audienceOptions.find((entry) => entry.id === audienceParam)?.id ?? null;
const scopeLabel = selectedAudience
	? `Built for ${productAudienceLabelMap[selectedAudience]}`
	: 'Built for Clients, Collaborators, and Investors';

const offerCards = productOffers
	.filter((offer) => (selectedAudience ? offer.audience.includes(selectedAudience) : true))
	.map((offer) => {
		const links: OfferLink[] = [];
		const proofHref = (() => {
			const href = offer.proofUrl ?? offer.caseStudyUrl ?? offer.repo;
			if (href.startsWith('http') || href.startsWith('//') || href.startsWith('mailto:')) {
				return href;
			}
			if (href.startsWith('/')) {
				return `${base}${href.slice(1)}`;
			}
			return href;
		})();
		if (proofHref) {
			links.push({
				label: offer.caseStudyUrl ? 'Case Study' : 'Proof',
				href: proofHref,
				external: proofHref.startsWith('http'),
				variant: 'proof',
			});
		}
		if (offer.demo) {
			links.push({
				label: 'Live Demo',
				href: offer.demo,
				external: true,
				variant: 'primary',
			});
		}
		links.push({
			label: 'GitHub',
			href: offer.repo,
			external: true,
			variant: 'secondary',
		});

		return {
			offer,
			links,
		};
	});

const typeGroups: Record<string, number> = { SaaS: 0, B2B: 0, B2C: 0, B2B2C: 0 };
offerCards.forEach((card) => {
	if (typeGroups[card.offer.type] !== undefined) {
		typeGroups[card.offer.type]++;
	}
});
const totalOffers = offerCards.length;

const CONTACT_API_BASE = (import.meta.env.PUBLIC_CONSULT_API_BASE ?? '').trim();
const CONTACT_API_URL = CONTACT_API_BASE
	? `${CONTACT_API_BASE.replace(/\/+$/, '')}/api/contact`
	: null;

function resolveAudienceLink(audience?: ProductAudience | null): string {
	return audience ? `${base}products/?audience=${audience}` : `${base}products/`;
}
---

<Layout title="What I Build — Product Offer" description="A practical offer page for clients, collaborators, and investors with proof, demos, and direct contact capture for each proposal path.">
	<div class="sketch-accent">
		<SketchContainer
			sketchId="pipeline"
			height="var(--space-4xl)"
			mobileHeight="var(--space-3xl)"
			ariaLabel="Animated pipeline visualization mapping proposal, proof, and delivery routes"
			data-chambers={Object.keys(typeGroups).join(',')}
			data-counts={Object.values(typeGroups).join(',')}
		/>
	</div>

	<section class="section">
		<div class="container">
			<h1 class="page-title">What I Build</h1>
			<p class="page-sub">
				Offer surface for real engagement: product evidence, live proof routes, and a direct contact capture path for people evaluating
				project fit before discovery calls.
			</p>

			<div class="audience-switch">
				<a class:list={['audience-switch__link', { 'audience-switch__link--active': !selectedAudience }]} href={resolveAudienceLink(null)}>All Offer Types</a>
				{audienceOptions.map((audience) => (
					<a
						class:list={[
							'audience-switch__link',
							{ 'audience-switch__link--active': selectedAudience === audience.id },
						]}
						href={resolveAudienceLink(audience.id)}
					>
						{audience.label}
					</a>
				))}
			</div>

			<div class="audience-summary">
				<div>
					<span class="audience-summary__scope">{scopeLabel}</span>
					<span class="audience-summary__count">{totalOffers} products shown</span>
				</div>
				<a href={`${base}products/?audience=collaborators#contact-form`} class="audience-summary__action"
					>Start a conversation for this gateway</a
				>
			</div>

			<h2 class="section__heading">Offer Grid</h2>
			<div class="product-grid">
				{offerCards.map((entry) => (
					<article class="product-card" data-offer-card>
						<div class="product-card__header">
							<div>
								<h3 class="product-card__name">{entry.offer.name}</h3>
								<p class="product-card__type" style={`--type-color: ${typeBadgeColors[entry.offer.type] || '#888'}`}>
									{entry.offer.type}
								</p>
							</div>
							<span class="product-card__status-badge" style={`--status-color: ${statusColors[entry.offer.status] || '#888'}`}>
								{entry.offer.status}
							</span>
						</div>
						<p class="product-card__desc">{entry.offer.description}</p>
						<p class="product-card__stack">{entry.offer.stack.join(' · ')}</p>
						<div class="product-card__audience">
							{entry.offer.audience.map((audience) => (
								<a href={resolveAudienceLink(audience)}>{productAudienceLabelMap[audience]}</a>
							))}
						</div>
						<div class="product-card__links">
							{entry.links.map((link) => (
								<a href={link.href} class={`product-card__link product-card__link--${link.variant}`} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>
									{link.label}
								</a>
							))}
							<a href={`${base}products/?audience=${selectedAudience ?? 'clients'}#contact-form`} class="product-card__link product-card__link--proof" data-offer={entry.offer.slug}>
								Contact about this offer
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section--soft" id="contact-form">
		<div class="container">
			<div class="contact-shell">
				<h2 class="section__heading">Contact Capture</h2>
				<p class="contact-intro">
					Use this form as the default intake for clients, collaborators, and investors. Messages are captured and routed via the portfolio API.
				</p>

				<form id="offer-contact-form" class="contact-form">
					<div class="form-grid">
						<div class="form-group">
							<label for="contact-name" class="form-label">Name</label>
							<input id="contact-name" name="name" class="form-input" type="text" autocomplete="name" />
						</div>

						<div class="form-group">
							<label for="contact-email" class="form-label">Email <span class="required">*</span></label>
							<input id="contact-email" name="email" class="form-input" type="email" required autocomplete="email" />
						</div>
					</div>

					<div class="form-grid">
						<div class="form-group">
							<label for="contact-audience" class="form-label">Audience</label>
							<select id="contact-audience" name="audience" class="form-select">
								<option value="">{selectedAudience ? productAudienceLabelMap[selectedAudience] : 'Client / Collaborator / Investor'}</option>
								{audienceOptions.map((audience) => (
									<option value={audience.id} selected={selectedAudience === audience.id}>
										{audience.label}
									</option>
								))}
							</select>
						</div>
						<div class="form-group">
							<label for="contact-offer" class="form-label">Offer</label>
							<select id="contact-offer" name="offer" class="form-select">
								<option value="">Select an offer</option>
								{productOffers.map((offer) => (
									<option value={offer.slug} data-audience={offer.audience.join(',')}>
										{offer.name}
									</option>
								))}
							</select>
						</div>
					</div>

					<div class="form-group">
						<label for="contact-message" class="form-label">Context / Goal <span class="required">*</span></label>
						<textarea
							id="contact-message"
							name="message"
							class="form-textarea"
							rows="6"
							required
							minlength="20"
							maxlength="2000"
							placeholder="What are you trying to ship, and what outcome do you need in 4-8 weeks?"
						/>
					</div>

					<input type="hidden" name="source" value="products-gateway" />
					<input type="hidden" id="contact-source-page" name="sourcePage" value={Astro.url.pathname} />

					<div class="contact-actions">
						<button type="submit" class="btn-submit">
							<span class="btn-submit__text">Submit</span>
							<span class="btn-submit__working" aria-hidden="true">Submitting...</span>
						</button>
					</div>
				</form>

				<p id="contact-status" class="contact-status" aria-live="polite" role="status"></p>
			</div>
		</div>
	</section>
</Layout>

<script lang="ts">
	const REQUEST_TIMEOUT_MS = 12000;
	const CONTACT_API_URL = ${CONTACT_API_URL ? JSON.stringify(CONTACT_API_URL) : 'null'};
	const form = document.getElementById('offer-contact-form') as HTMLFormElement | null;
	const status = document.getElementById('contact-status') as HTMLParagraphElement | null;

	interface ContactApiSuccess {
		ok: true;
		requestId: string;
		message?: string;
	}

	interface ContactApiFailure {
		ok: false;
		code: string;
		message: string;
		requestId?: string;
	}

	function formatAudienceOrFallback(value: string | null): string {
		return value && value.length > 0 ? value : 'clients';
	}

	function setFormDefaults() {
		const params = new URLSearchParams(window.location.search);
		const audience = formatAudienceOrFallback(params.get('audience'));
		const audienceSelect = document.getElementById('contact-audience') as HTMLSelectElement | null;
		if (audienceSelect) {
			audienceSelect.value = audience;
		}
	}

	function fillOfferFromCard(event: Event) {
		const target = event.target as HTMLAnchorElement;
		const offer = target.getAttribute('data-offer');
		const contactOffer = document.getElementById('contact-offer') as HTMLSelectElement | null;
		if (offer && contactOffer) {
			contactOffer.value = offer;
		}
		const contactSection = document.getElementById('contact-form');
		if (contactSection) {
			contactSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
		}
	}

	async function submitContactForm(event: SubmitEvent) {
		event.preventDefault();
		if (!form || !status) return;

		status.textContent = '';
		status.classList.remove('contact-status--success', 'contact-status--error');
		const submitBtn = form.querySelector<HTMLButtonElement>('.btn-submit');
		const submitText = form.querySelector<HTMLSpanElement>('.btn-submit__text');
		const workingText = form.querySelector<HTMLSpanElement>('.btn-submit__working');

		if (!CONTACT_API_URL) {
			status.classList.add('contact-status--error');
			status.textContent = 'Contact endpoint is not configured. Email is preferred fallback: padavano.anthony@gmail.com';
			return;
		}

		if (submitBtn && submitText && workingText) {
			submitBtn.disabled = true;
			submitText.hidden = true;
			workingText.hidden = false;
		}

		try {
			const formData = new FormData(form);
			const payload = {
				name: String(formData.get('name') || '').trim() || null,
				email: String(formData.get('email') || '').trim(),
				audience: String(formData.get('audience') || '').trim() || 'clients',
				offer: String(formData.get('offer') || '').trim() || null,
				message: String(formData.get('message') || '').trim(),
				source: String(formData.get('source') || 'products-gateway').trim(),
				sourcePage: String(formData.get('sourcePage') || window.location.pathname),
			};

			const controller = new AbortController();
			const timeout = window.setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);

			const response = await fetch(CONTACT_API_URL, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
				signal: controller.signal,
			});
			window.clearTimeout(timeout);

			const responseBody = (await response.json()) as ContactApiSuccess | ContactApiFailure;
			if (!response.ok || !responseBody.ok) {
				const failure = responseBody as ContactApiFailure;
				throw new Error(failure.message || `Contact API returned ${response.status}`);
			}

			const payloadSuccess = responseBody as ContactApiSuccess;
			form.reset();
			setFormDefaults();
			status.classList.add('contact-status--success');
			status.textContent = `Message captured. Request id: ${payloadSuccess.requestId}. I will reply with project fit details.`;
		} catch (error) {
			status.classList.add('contact-status--error');
			status.textContent =
				error instanceof Error ? error.message : 'Could not send the contact request. Email is preferred fallback: padavano.anthony@gmail.com';
		} finally {
			if (submitBtn && submitText && workingText) {
				submitBtn.disabled = false;
				submitText.hidden = false;
				workingText.hidden = true;
			}
		}
	}

	function initProductsContact() {
		if (!form) return;
		if (form.dataset.initialized === 'true') return;
		form.dataset.initialized = 'true';

		setFormDefaults();
		form.addEventListener('submit', submitContactForm);

		document.querySelectorAll<HTMLAnchorElement>('[data-offer]')?.forEach((link) => {
			link.addEventListener('click', fillOfferFromCard);
		});
	}

	document.addEventListener('astro:page-load', initProductsContact);
	initProductsContact();
</script>

<style>
	.page-sub {
		max-width: 52ch;
	}

	.audience-switch {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-bottom: var(--space-md);
	}

	.audience-switch__link {
		padding: calc(var(--space-xs) * 0.8) var(--space-sm);
		border-radius: var(--radius-sm);
		border: 1px solid var(--border);
		text-decoration: none;
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.audience-switch__link:hover,
	.audience-switch__link--active {
		border-color: var(--accent);
		color: var(--accent-text);
	}

	.audience-summary {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		align-items: baseline;
		justify-content: space-between;
		background: var(--bg-card);
		border: 1px solid var(--border);
		padding: var(--space-md);
		border-radius: var(--radius);
		margin-bottom: var(--space-xl);
	}

	.audience-summary__scope {
		display: inline-block;
		font-size: 1rem;
		font-weight: 600;
		margin-right: var(--space-sm);
		color: var(--accent);
	}

	.audience-summary__count {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.audience-summary__action {
		color: var(--accent-text);
		font-weight: 600;
		text-decoration: none;
	}

	.audience-summary__action:hover {
		text-decoration: underline;
	}

	.product-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
		gap: var(--space-lg);
	}

	.product-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: var(--space-lg);
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		transition: border-color var(--transition-fast);
	}

	.product-card:hover {
		border-color: var(--text-muted);
	}

	.product-card__header {
		display: flex;
		justify-content: space-between;
		gap: var(--space-sm);
		align-items: flex-start;
	}

	.product-card__name {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.3;
	}

	.product-card__type {
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.15em 0.55em;
		border-radius: 3px;
		border: 1px solid var(--type-color);
		color: var(--type-color);
	}

	.product-card__desc {
		color: var(--text-secondary);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.product-card__status-badge {
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.15em 0.5em;
		border-radius: 3px;
		border: 1px solid var(--status-color);
		color: var(--status-color);
	}

	.product-card__stack {
		font-family: var(--font-mono);
		color: var(--text-muted);
		font-size: 0.74rem;
	}

	.product-card__audience {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}

	.product-card__audience a {
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.1rem 0.5rem;
		font-size: 0.7rem;
		color: var(--text-secondary);
		text-decoration: none;
	}

	.product-card__audience a:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.product-card__links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-top: auto;
	}

	.product-card__link {
		font-size: 0.84rem;
		text-decoration: none;
	}

	.product-card__link--proof {
		color: var(--text-secondary);
	}

	.product-card__link--primary,
	.product-card__link--proof {
		color: var(--accent-text);
		font-weight: 600;
	}

	.product-card__link--secondary {
		color: var(--text-secondary);
	}

	.product-card__link:hover {
		opacity: 0.8;
	}

	.section--soft {
		background: color-mix(in oklab, var(--bg-card) 78%, transparent);
	}

	.contact-shell {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
	}

	.contact-intro {
		max-width: 65ch;
		color: var(--text-secondary);
	}

	.contact-form {
		display: grid;
		gap: var(--space-md);
	}

	.form-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--space-md);
	}

	.form-group {
		display: grid;
		gap: var(--space-xs);
	}

	.form-label {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.required {
		color: var(--cmyk-yellow);
	}

	.form-input,
	.form-select,
	.form-textarea {
		background: var(--bg-primary);
		color: var(--text-primary);
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		padding: var(--space-sm);
		font: inherit;
		font-size: 0.9rem;
	}

	.form-input:focus,
	.form-select:focus,
	.form-textarea:focus {
		outline: 2px solid color-mix(in oklab, var(--accent) 52%, transparent);
		outline-offset: 1px;
	}

	.contact-actions {
		display: flex;
		justify-content: flex-start;
	}

	.btn-submit {
		position: relative;
		border: 1px solid var(--accent);
		border-radius: var(--radius-md);
		background: var(--accent);
		color: var(--bg-primary);
		padding: var(--space-sm) var(--space-xl);
		font-weight: 600;
	}

	.btn-submit:disabled {
		opacity: 0.7;
	}

	.btn-submit__working {
		display: none;
	}

	.btn-submit:disabled .btn-submit__text {
		display: none;
	}

	.btn-submit:disabled .btn-submit__working {
		display: inline;
	}

	.contact-status {
		margin-top: var(--space-sm);
		min-height: 1.2rem;
	}

	.contact-status--success {
		color: var(--success);
	}

	.contact-status--error {
		color: var(--failure);
	}

	@media (max-width: 768px) {
		.form-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
