---
import MermaidDiagram from '../components/academic/MermaidDiagram.astro';
import StatGrid from '../components/StatGrid.astro';
import omegaData from '../data/omega.json';
import systemMetrics from '../data/system-metrics.json';
import vitals from '../data/vitals.json';
import Layout from '../layouts/Layout.astro';

const impactMetrics = [
	{ value: vitals.repos.total.toString(), label: 'Repos Managed' },
	{ value: vitals.substance.test_files.toLocaleString(), label: 'Test Files' },
	{ value: `${Math.round(vitals.logos.words / 1000)}K+`, label: 'Words Written' },
	{ value: vitals.substance.ci_passing.toString(), label: 'CI Workflows Passing' },
	{ value: `${vitals.substance.ci_coverage_pct}%`, label: 'Avg. Coverage' },
	{ value: omegaData.soak.streak_days.toString(), label: 'Soak Days' },
];

const scaleMetrics = [
	{ value: vitals.repos.orgs.toString(), label: 'GitHub Orgs' },
	{ value: vitals.repos.active.toString(), label: 'Active Repos' },
	{ value: vitals.substance.code_files.toLocaleString(), label: 'Code Files' },
	{ value: vitals.substance.test_files.toLocaleString(), label: 'Test Files' },
	{ value: vitals.logos.essays.toString(), label: 'Published Essays' },
	{ value: systemMetrics.computed.dependency_edges.toString(), label: 'Dependency Edges' },
];
---

<Layout title="System Impact — Evidence of Reach" description="Real-world metrics, API usage, and structural influence of the ORGANVM system.">
  <section class="section">
    <div class="container">
      <h1 class="page-title">System Impact</h1>
      <p class="page-sub">
        Quantitative evidence of architectural performance and structural depth across the eight-organ ecosystem.
      </p>

      <StatGrid stats={impactMetrics} />

      <h2 class="section__heading" data-reveal>System Scale</h2>
      <p>
        The ORGANVM architecture spans {vitals.repos.orgs} GitHub organizations, {vitals.repos.total} repositories,
        and {systemMetrics.computed.total_words_short} of documented knowledge. Every organ is independently governed
        with machine-readable promotion criteria and automated dependency validation.
      </p>

      <StatGrid stats={scaleMetrics} />

      <h2 class="section__heading" data-reveal>Data Flow & Orchestration</h2>
      <p>
        The system serves as a central intelligence hub, coordinating state transitions across 91 leaf nodes.
        Each organ produces and consumes discrete data artifacts, ensuring that "impact" is measurable at the protocol level.
      </p>

      <MermaidDiagram
        caption="Inter-Organ Impact Graph: How data artifacts flow from theoretical foundations to public distribution."
        chart={`graph LR
    I[Theory] -->|Ontology| II[Art]
    II -->|Media| III[Commerce]
    III -->|Revenue| IV[Orchestration]
    IV -->|Registry| V[Logos]
    V -->|Vitals| VI[Community]
    VI -->|Feedback| VII[Distribution]
    VII -->|Reach| VIII[Meta]
    style V fill:#00bcd4,stroke:#333,stroke-width:4px`}
      />

      <h2 class="section__heading" data-reveal>Structural Proof</h2>
      <div class="grid">
        <div class="card" data-reveal>
          <h3>Adversarial Extraction</h3>
          <p>Successful normalization of 50-state public record data schemas through the Ergon data pipeline.</p>
        </div>
        <div class="card" data-reveal>
          <h3>Linguistic Scaling</h3>
          <p>Processing of 46 canonical works in 15+ languages using the Linguistic Atomization Framework.</p>
        </div>
        <div class="card" data-reveal>
          <h3>Autonomous Governance</h3>
          <p>{omegaData.soak.streak_days} consecutive days of zero-incident operations under the fully automated quality ratchet system.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: var(--space-lg);
    border-radius: 8px;
  }
  .card h3 {
    margin-top: 0;
    color: var(--accent);
    font-size: 1.25rem;
  }
</style>
